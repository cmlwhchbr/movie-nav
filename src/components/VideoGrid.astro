---
import { catalogPrimaryPlayUrl, type CatalogVideo } from "../lib/catalog";

const { items = [] } = Astro.props as { items: CatalogVideo[] };
---

<div class="video-grid-clone">
  {items.map((item) => (
    <article class="video-card-clone">
      <a href={catalogPrimaryPlayUrl(item)} aria-label={`播放${item.name}`}>
        <img src={item.pic || "/favicon.svg"} alt={item.name} loading="lazy" />
      </a>
      <a href={catalogPrimaryPlayUrl(item)}>
        <h3 class="video-card-clone__title">{item.name}</h3>
        <span class="video-card-clone__meta">{item.type || item.year || "站内资源"}</span>
        <span class="video-card-clone__meta">{item.actor || item.area || `播放 ${item.hits}`}</span>
      </a>
    </article>
  ))}
</div>

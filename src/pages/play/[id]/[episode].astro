---
import "../../../styles/global.css";
import Header from "../../../components/Header.astro";
import VideoGrid from "../../../components/VideoGrid.astro";
import { catalogDetailUrl, catalogPlayUrl, getCatalogVideo, relatedCatalogVideos } from "../../../lib/catalog";
import { env } from "../../../lib/env";
import { isDirectVideo } from "../../../lib/maccms";
import { safeTags, sceneTags } from "../../../lib/tags";

const runtime = env(Astro);
const siteName = runtime.SITE_NAME || "成人视频导航";
const id = Astro.params.id || "";
const episodeIndex = Number(Astro.params.episode || 0);
const line = Number(Astro.url.searchParams.get("line") || 0);
const vod = await getCatalogVideo(runtime, id);

if (!vod) {
  return new Response("Not Found", { status: 404 });
}

const source = (vod.play_sources || []).find((item) => item.source_index === line) || vod.play_sources?.[0];
const current = source?.episodes.find((item) => item.episode_index === episodeIndex) || source?.episodes[0];
if (!source || !current) {
  return new Response("Not Found", { status: 404 });
}

const failedLines = new Set(
  (Astro.url.searchParams.get("failed") || "")
    .split(",")
    .map((value) => Number(value))
    .filter((value) => Number.isInteger(value))
);
const nextSource = nextPlayableSource(vod.play_sources || [], source.source_index, failedLines);
const nextEpisode = nextSource?.episodes.find((item) => item.episode_index === current.episode_index) || nextSource?.episodes[0];
const nextLineUrl = nextSource && nextEpisode
  ? withFailedLines(catalogPlayUrl(vod, nextSource.source_index, nextEpisode.episode_index), [...failedLines, source.source_index])
  : "";
const needsFallbackParser = /aosika/i.test(current.player || source.source_code);
const useIframePlayer = !isDirectVideo(current.url);
const lineStartTimes: Record<number, number> = {
  0: 30,
  1: 30,
  2: 17,
  3: 11,
  4: 20
};
const startAt = lineStartTimes[source.source_index] || 0;
const playerUrl = current.url;
const fallbackParserUrl = needsFallbackParser ? `https://askvodbf.com/play.html?url=${current.url}` : "";
const related = await relatedCatalogVideos(runtime, vod, 8);
const searchTerms = stableSample(safeTags(sceneTags), `${vod.source_vod_id}-${source.source_index}-${current.episode_index}`, 18);

function stableSample(values: string[], seedText: string, limit: number): string[] {
  let seed = 0;
  for (let index = 0; index < seedText.length; index += 1) {
    seed = (seed * 31 + seedText.charCodeAt(index)) >>> 0;
  }

  return values
    .map((value, index) => ({ value, rank: seededRank(seed + index * 9973) }))
    .sort((a, b) => a.rank - b.rank)
    .slice(0, limit)
    .map((item) => item.value);
}

function seededRank(seed: number): number {
  let value = seed || 1;
  value ^= value << 13;
  value ^= value >>> 17;
  value ^= value << 5;
  return value >>> 0;
}

function nextPlayableSource(sources: NonNullable<typeof vod.play_sources>, currentIndex: number, failed: Set<number>) {
  const ordered = [...sources].filter((item) => item.episodes.length > 0).sort((a, b) => a.source_index - b.source_index);
  const candidates = [
    ...ordered.filter((item) => item.source_index > currentIndex),
    ...ordered.filter((item) => item.source_index < currentIndex)
  ];

  return candidates.find((item) => !failed.has(item.source_index)) || null;
}

function withFailedLines(url: string, failed: number[]): string {
  const unique = [...new Set(failed)].join(",");
  return `${url}&failed=${encodeURIComponent(unique)}`;
}
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{current.name} - {vod.name} - {siteName}</title>
  </head>
  <body>
    <Header siteName={siteName} />
    <main class="page py-6">
      <section class="mb-5">
        <div class="mb-3 flex flex-wrap items-center gap-2 text-sm text-zinc-400">
          <a class="hover:text-white" href={catalogDetailUrl(vod)}>详情</a>
          <span>/</span>
          <span>线路 {source.source_index + 1}</span>
          <span>/</span>
          <span>{current.name}</span>
        </div>
        <h1 class="text-2xl font-black">{vod.name}</h1>
      </section>

      <section class="mx-auto max-w-5xl rounded-md border border-zinc-800 bg-black">
        {!useIframePlayer ? (
          <video
            id="videoPlayer"
            class="aspect-video w-full bg-black"
            data-src={playerUrl}
            data-start-at={startAt}
            data-fallback-src={fallbackParserUrl}
            data-next-line-url={nextLineUrl}
            controls
            playsinline
            preload="metadata"
          ></video>
        ) : (
          <iframe class="aspect-video min-h-[260px] w-full border-0 bg-black" src={playerUrl} allow="autoplay; encrypted-media; picture-in-picture; fullscreen" allowfullscreen></iframe>
        )}
      </section>
      {nextLineUrl && (
        <p id="autoSwitchStatus" class="mt-2 text-sm text-zinc-500" data-next-line-url={nextLineUrl}>
          当前线路卡顿或无法播放时会自动切换下一线路
        </p>
      )}
      <div class="mt-3 flex flex-wrap gap-2">
        {searchTerms.map((term) => (
          <a class="rounded border border-zinc-800 bg-zinc-900 px-3 py-2 text-sm text-zinc-300 hover:border-rose-500 hover:text-white" href={`/search?q=${encodeURIComponent(term)}`}>
            {term}
          </a>
        ))}
      </div>

      <section class="mt-5 rounded-md border border-zinc-800 bg-zinc-900 p-4">
        <div class="mb-3 flex flex-wrap gap-2">
          {(vod.play_sources || []).map((item) => (
            <a class={`pill ${item.source_index === source.source_index ? "border-rose-500 text-white" : ""}`} href={catalogPlayUrl(vod, item.source_index, item.episodes[0]?.episode_index || 0)}>
              线路 {item.source_index + 1} {item.source_code}
            </a>
          ))}
        </div>
        <div class="flex flex-wrap gap-2">
          {source.episodes.map((ep) => (
            <a class={`pill ${ep.episode_index === current.episode_index ? "border-rose-500 text-white" : ""}`} href={catalogPlayUrl(vod, source.source_index, ep.episode_index)}>
              {ep.name}
            </a>
          ))}
        </div>
      </section>

      <section class="mt-8">
        <h2 class="mb-4 text-xl font-bold">相关推荐</h2>
        <VideoGrid items={related} />
      </section>
    </main>
    <script>
      import Hls from "hls.js/dist/hls.light.mjs";

      const video = document.querySelector<HTMLVideoElement>("#videoPlayer");
      const autoSwitchStatus = document.querySelector<HTMLElement>("#autoSwitchStatus");
      const iframeNextLineUrl = autoSwitchStatus?.dataset.nextLineUrl || "";

      if (video) {
        const src = video.dataset.src || "";
        const startAt = Number(video.dataset.startAt || 0);
        const fallbackSrc = video.dataset.fallbackSrc || "";
        const nextLineUrl = video.dataset.nextLineUrl || "";
        let didSeek = false;
        let seekTimer = 0;
        let firstPlayTime = 0;
        let hasStartedPlayback = false;
        let startupTimer = 0;
        let didSwitch = false;

        const switchToNextLine = (reason: string) => {
          if (didSwitch || hasStartedPlayback || !nextLineUrl) return;
          didSwitch = true;
          if (autoSwitchStatus) {
            autoSwitchStatus.textContent = `当前线路${reason}，正在切换下一线路...`;
          }
          window.location.href = nextLineUrl;
        };

        const markProgress = () => {
          if (video.currentTime > firstPlayTime + 2) {
            hasStartedPlayback = true;
            window.clearTimeout(startupTimer);
            if (autoSwitchStatus) {
              autoSwitchStatus.textContent = "当前线路正在播放";
            }
          }
        };

        const startHealthCheck = () => {
          window.clearTimeout(startupTimer);
          firstPlayTime = video.currentTime;

          startupTimer = window.setTimeout(() => {
            if (!hasStartedPlayback && !video.paused && video.currentTime <= firstPlayTime + 0.5) {
              switchToNextLine("加载过慢");
            }
          }, 20000);
        };

        const scheduleSeek = () => {
          if (!startAt || didSeek || seekTimer || video.readyState < 3) return;
          seekTimer = window.setTimeout(() => {
            didSeek = true;
            try {
              video.currentTime = startAt;
            } catch {
              didSeek = false;
            }
          }, 500);
        };

        const fallbackToParser = () => {
          if (!fallbackSrc) return;
          const iframe = document.createElement("iframe");
          iframe.className = "h-[62vh] min-h-[260px] w-full border-0 bg-black";
          iframe.src = fallbackSrc;
          iframe.allow = "autoplay; encrypted-media; picture-in-picture; fullscreen";
          iframe.allowFullscreen = true;
          video.replaceWith(iframe);
        };

        if (/\.m3u8(\?|$)/i.test(src) && Hls.isSupported()) {
          const hls = new Hls({
            enableWorker: true,
            lowLatencyMode: false,
            startPosition: startAt || -1
          });
          hls.loadSource(src);
          hls.attachMedia(video);
          hls.on(Hls.Events.ERROR, (_event, data) => {
            if (data.fatal) {
              if (!hasStartedPlayback && nextLineUrl) {
                hls.destroy();
                switchToNextLine("无法播放");
              } else if (fallbackSrc) {
                hls.destroy();
                fallbackToParser();
              } else {
                hls.recoverMediaError();
                video.src = src;
              }
            }
          });
        } else {
          video.addEventListener("canplay", scheduleSeek);
          video.addEventListener("play", scheduleSeek);
          video.addEventListener("playing", scheduleSeek);
          video.addEventListener("timeupdate", scheduleSeek);
          video.addEventListener("ended", () => {
            window.clearTimeout(seekTimer);
          });
          video.src = src;
        }

        video.addEventListener("play", startHealthCheck);
        video.addEventListener("playing", markProgress);
        video.addEventListener("timeupdate", markProgress);
        video.addEventListener("error", () => switchToNextLine("播放失败"));
        video.addEventListener("ended", () => {
          window.clearTimeout(startupTimer);
        });

      }

    </script>
  </body>
</html>

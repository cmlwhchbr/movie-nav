---
import { safeTags, sceneTags } from "../lib/tags";

const { class: className = "" } = Astro.props as { class?: string };
const searchTags = safeTags(sceneTags);
---

<section class={`keyword-panel ${className}`}>
  <h2>关键词找片</h2>
  <div class="keyword-panel__links">
    {searchTags.map((tag) => (
      <a href={`/search?q=${encodeURIComponent(tag)}`}>
        {tag}
      </a>
    ))}
  </div>
</section>

---
import "../styles/global.css";
import Header from "../components/Header.astro";
import KeywordSearchPanel from "../components/KeywordSearchPanel.astro";
import VideoGrid from "../components/VideoGrid.astro";
import { listCatalogVideos } from "../lib/catalog";
import { env } from "../lib/env";

const runtime = env(Astro);
const siteName = runtime.SITE_NAME || "成人视频导航";
const q = Astro.url.searchParams.get("q") || "";
const page = Math.max(Number(Astro.url.searchParams.get("page") || 1), 1);
const limit = 15;
let list = [];
let error = "";

if (q.trim()) {
  try {
    list = await listCatalogVideos(runtime, { keyword: q, order: "latest", limit, offset: (page - 1) * limit });
  } catch (exception) {
    error = exception instanceof Error ? exception.message : "搜索失败";
  }
}
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{q ? `搜索：${q}` : "搜索"} - {siteName}</title>
  </head>
  <body>
    <Header siteName={siteName} />
    <main class="main-offset page">
      {!q.trim() ? (
        <section>
          <h1 class="clone-title">搜索</h1>
          <form class="mx-auto grid max-w-3xl grid-cols-[1fr_auto] gap-0 overflow-hidden rounded-md border border-[#ba4a7b] bg-white shadow-md" action="/search">
            <input class="min-w-0 px-4 py-3 text-base text-neutral-700 outline-none placeholder:text-neutral-400" name="q" value={q} placeholder="输入片名、女优、番号、标签" />
            <button class="bg-[#ba4a7b] px-6 py-3 text-sm font-semibold text-white hover:bg-[#a23b6b]">搜寻</button>
          </form>
          <KeywordSearchPanel />
          {error && <p class="mt-3 text-sm text-red-600">搜索失败：{error}</p>}
        </section>
      ) : (
        <section>
          <h1 class="clone-title">搜索：{q}</h1>
          <div class="clone-more"><a href="/search">返回搜索词&gt;&gt;</a></div>
          {error && <p class="w-full text-sm text-red-600">搜索失败：{error}</p>}
        </section>
      )}
      <VideoGrid items={list} />
      {q && (
        <div class="mt-7 flex justify-center gap-3">
          {page > 1 && <a class="pill" href={`/search?q=${encodeURIComponent(q)}&page=${page - 1}`}>上一页</a>}
          {list.length === limit && <a class="pill" href={`/search?q=${encodeURIComponent(q)}&page=${page + 1}`}>加载更多</a>}
        </div>
      )}
      {q.trim() && (
        <KeywordSearchPanel class="mt-10" />
      )}
    </main>
  </body>
</html>

---
import "../styles/global.css";
import { searchVod } from "../lib/maccms";
import { env } from "../lib/env";

const runtime = env(Astro);
const q = Astro.url.searchParams.get("q") || "";
let list = [];
let error = "";

if (q.trim()) {
  try {
    list = await searchVod(runtime.MACCMS_API, q);
  } catch (exception) {
    error = exception instanceof Error ? exception.message : "搜索失败";
  }
}
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{q ? `搜索：${q}` : "搜索"} - {runtime.SITE_NAME}</title>
  </head>
  <body>
    <header class="topbar">
      <div class="page bar">
        <a class="brand" href="/">{runtime.SITE_NAME}</a>
        <nav class="nav"><a href="/">首页</a></nav>
      </div>
    </header>
    <main class="page">
      <section class="hero">
        <h1>搜索影视资源</h1>
        <form class="search" action="/search">
          <input name="q" value={q} placeholder="输入电影、电视剧、演员" />
          <button>搜索</button>
        </form>
        {error && <p style="color: var(--danger)">搜索失败：{error}</p>}
      </section>
      <section class="list">
        {list.map((vod) => (
          <article class="row">
            <img class="poster" src={vod.pic || "/favicon.svg"} alt={vod.name} loading="lazy" />
            <div>
              <h3><a href={`/detail/${vod.id}`}>{vod.name}</a></h3>
              <p class="muted">{vod.type} · {vod.year} · {vod.note}</p>
            </div>
            <a class="btn" href={`/detail/${vod.id}`}>播放</a>
          </article>
        ))}
      </section>
    </main>
  </body>
</html>

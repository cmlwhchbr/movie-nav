---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import VideoGrid from "../../components/VideoGrid.astro";
import { catalogPlayUrl, getCatalogVideo, relatedCatalogVideos } from "../../lib/catalog";
import { env } from "../../lib/env";

const runtime = env(Astro);
const siteName = runtime.SITE_NAME || "成人视频导航";
const id = Astro.params.id || "";
const vod = await getCatalogVideo(runtime, id);

if (!vod) {
  return new Response("Not Found", { status: 404 });
}

const related = await relatedCatalogVideos(runtime, vod, 8);
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{vod.name} - {siteName}</title>
    <meta name="description" content={vod.description || vod.note || vod.name} />
  </head>
  <body>
    <Header siteName={siteName} />
    <main class="main-offset page">
      <h1 class="view-title">{vod.name}</h1>
      <section class="mt-6 grid gap-5 lg:grid-cols-[minmax(320px,520px)_1fr]">
        <img class="aspect-video w-full object-cover shadow-md shadow-black/30" src={vod.pic || "/favicon.svg"} alt={vod.name} />
        <div>
          <div class="mt-3 flex flex-wrap gap-2 text-sm text-neutral-500">
            {vod.type && <a class="pill" href={`/category/${encodeURIComponent(vod.type)}`}>{vod.type}</a>}
            {vod.year && <span class="pill">{vod.year}</span>}
            {vod.note && <span class="pill">{vod.note}</span>}
            <span class="pill">播放 {vod.hits}</span>
          </div>
          <p class="mt-4 text-sm leading-7 text-neutral-600">{vod.description || "暂无简介"}</p>
          <div class="mt-4 grid gap-2 text-sm text-neutral-500">
            <p>演员：{vod.actor || "-"}</p>
            <p>导演：{vod.director || "-"}</p>
            <p>地区：{vod.area || "-"}</p>
          </div>
        </div>
      </section>

      <section class="mt-8">
        <h2 class="clone-title">播放线路</h2>
        <div class="space-y-5">
          {(vod.play_sources || []).map((source) => (
            <div class="line-panel">
              <div class="mb-3 flex items-center gap-2">
                <h3 class="font-semibold">线路 {source.source_index + 1}</h3>
                <span class="text-sm text-neutral-500">{source.source_code}</span>
              </div>
              <div class="flex flex-wrap gap-2">
                {source.episodes.map((ep) => (
                  <a class="pill" href={catalogPlayUrl(vod, source.source_index, ep.episode_index)}>{ep.name}</a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="mt-8">
        <h2 class="clone-title">相关推荐</h2>
        <VideoGrid items={related} />
      </section>
      <footer class="clone-footer">
        <a href="/">老司机 laosiji.xyz</a>
        <p>每日更新影视资源导航</p>
      </footer>
    </main>
  </body>
</html>

---
import "../styles/global.css";
import Header from "../components/Header.astro";
import VideoGrid from "../components/VideoGrid.astro";
import { listCatalogVideos } from "../lib/catalog";
import { env } from "../lib/env";
import { safeTags, sceneTags } from "../lib/tags";

const runtime = env(Astro);
const siteName = runtime.SITE_NAME || "成人视频导航";
const q = Astro.url.searchParams.get("q") || "";
const page = Math.max(Number(Astro.url.searchParams.get("page") || 1), 1);
const limit = 32;
let list = [];
let error = "";
const searchTags = safeTags(sceneTags);

if (q.trim()) {
  try {
    list = await listCatalogVideos(runtime, { keyword: q, order: "latest", limit, offset: (page - 1) * limit });
  } catch (exception) {
    error = exception instanceof Error ? exception.message : "搜索失败";
  }
}
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{q ? `搜索：${q}` : "搜索"} - {siteName}</title>
  </head>
  <body>
    <Header siteName={siteName} />
    <main class="page py-6">
      {!q.trim() ? (
        <section class="mb-6 rounded-md border border-zinc-800 bg-zinc-900 p-5">
          <h1 class="mb-4 text-2xl font-black">搜索</h1>
          <form class="grid grid-cols-[1fr_auto] gap-2" action="/search">
            <input class="min-w-0 rounded border border-zinc-700 bg-zinc-950 px-4 py-3 text-sm outline-none focus:border-rose-500" name="q" value={q} placeholder="输入片名、女优、番号、标签" />
            <button class="rounded bg-rose-600 px-5 py-3 text-sm font-semibold text-white hover:bg-rose-500">搜索</button>
          </form>
          <div class="mt-5">
            <h2 class="mb-3 text-base font-bold text-zinc-200">关键词找片</h2>
            <div class="flex flex-wrap gap-2">
              {searchTags.map((tag) => (
                <a class="rounded border border-zinc-700 bg-zinc-950 px-3 py-2 text-sm text-zinc-300 hover:border-rose-500 hover:text-white" href={`/search?q=${encodeURIComponent(tag)}`}>
                  {tag}
                </a>
              ))}
            </div>
          </div>
          {error && <p class="mt-3 text-sm text-red-400">搜索失败：{error}</p>}
        </section>
      ) : (
        <section class="mb-5 flex flex-wrap items-center justify-between gap-3 rounded-md border border-zinc-800 bg-zinc-900 px-4 py-3">
          <div>
            <p class="text-sm text-zinc-500">当前搜索词</p>
            <h1 class="text-xl font-bold text-white">{q}</h1>
          </div>
          <div class="flex flex-wrap gap-2">
            <a class="pill" href="/search">返回搜索词</a>
            <a class="pill" href="/tags">关键词找片</a>
          </div>
          {error && <p class="w-full text-sm text-red-400">搜索失败：{error}</p>}
        </section>
      )}
      <VideoGrid items={list} />
      {q && (
        <div class="mt-7 flex justify-center gap-3">
          {page > 1 && <a class="pill" href={`/search?q=${encodeURIComponent(q)}&page=${page - 1}`}>上一页</a>}
          {list.length === limit && <a class="pill" href={`/search?q=${encodeURIComponent(q)}&page=${page + 1}`}>加载更多</a>}
        </div>
      )}
      {q.trim() && (
        <section class="mt-10 rounded-md border border-zinc-800 bg-zinc-900 p-5">
          <div>
            <h2 class="mb-3 text-base font-bold text-zinc-200">关键词找片</h2>
            <div class="flex flex-wrap gap-2">
              {searchTags.map((tag) => (
                <a class="rounded border border-zinc-700 bg-zinc-950 px-3 py-2 text-sm text-zinc-300 hover:border-rose-500 hover:text-white" href={`/search?q=${encodeURIComponent(tag)}`}>
                  {tag}
                </a>
              ))}
            </div>
          </div>
        </section>
      )}
    </main>
  </body>
</html>

---
const { title, items } = Astro.props;
const detailHref = (item) => `/detail/${item.vod.id}`;
---

<section>
  <div class="section-title">
    <h2>{title}</h2>
    <span class="muted">{items.length} 条</span>
  </div>
  <div class="grid">
    {items.map((item, index) => (
      <article class="card">
        <a
          class="poster-link"
          href={detailHref(item)}
          aria-label={`查看${item.title}`}
        >
          <img class="poster" src={item.vod?.pic || item.image || "/favicon.svg"} alt={item.title} loading="lazy" />
        </a>
        <div>
          <div class="rank">#{index + 1} {item.hotScore}</div>
          <h3>
            <a href={detailHref(item)}>{item.title}</a>
          </h3>
          <p class="desc">{item.vod?.note || item.desc || "点击搜索站内播放资源"}</p>
        </div>
      </article>
    ))}
  </div>
</section>

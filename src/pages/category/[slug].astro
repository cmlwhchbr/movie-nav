---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import VideoGrid from "../../components/VideoGrid.astro";
import { listCatalogVideos } from "../../lib/catalog";
import { env } from "../../lib/env";

const runtime = env(Astro);
const siteName = runtime.SITE_NAME || "成人视频导航";
const slug = decodeURIComponent(Astro.params.slug || "latest");
const page = Math.max(Number(Astro.url.searchParams.get("page") || 1), 1);
const limit = 16;
const offset = (page - 1) * limit;
const options = slug === "hot"
  ? { order: "hot" as const, limit, offset }
  : slug === "latest"
    ? { order: "latest" as const, limit, offset }
    : { type: slug, order: "latest" as const, limit, offset };
const items = await listCatalogVideos(runtime, options);
const title = slug === "hot" ? "热门播放" : slug === "latest" ? "最新更新" : slug;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} - {siteName}</title>
  </head>
  <body>
    <Header siteName={siteName} />
    <main class="page py-6">
      <div class="mb-5 flex items-end justify-between gap-3">
        <h1 class="text-2xl font-black">{title}</h1>
        <a class="text-sm text-zinc-400 hover:text-white" href="/category">全部分类</a>
      </div>
      <VideoGrid items={items} />
      <div class="mt-7 flex justify-center gap-3">
        {page > 1 && <a class="pill" href={`/category/${encodeURIComponent(slug)}?page=${page - 1}`}>上一页</a>}
        {items.length === limit && <a class="pill" href={`/category/${encodeURIComponent(slug)}?page=${page + 1}`}>加载更多</a>}
      </div>
    </main>
  </body>
</html>

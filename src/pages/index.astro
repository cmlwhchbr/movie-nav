---
import "../styles/global.css";
import Header from "../components/Header.astro";
import VideoGrid from "../components/VideoGrid.astro";
import { listCatalogVideos } from "../lib/catalog";
import { env } from "../lib/env";

const runtime = env(Astro);
const siteName = runtime.SITE_NAME || "成人视频导航";
let latest = [];
let domestic = [];
let gossip = [];
let japanKorea = [];
let hot = [];
let error = "";

try {
  [latest, domestic, gossip, japanKorea, hot] = await Promise.all([
    listCatalogVideos(runtime, { order: "latest", limit: 4 }),
    listCatalogVideos(runtime, { type: "国产", order: "latest", limit: 8 }),
    listCatalogVideos(runtime, { tag: "黑料", order: "latest", limit: 8 }),
    listCatalogVideos(runtime, { type: "日韩", order: "latest", limit: 8 }),
    listCatalogVideos(runtime, { order: "hot", limit: 8 })
  ]);
} catch (exception) {
  error = exception instanceof Error ? exception.message : "数据读取失败";
}
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteName}</title>
    <meta name="description" content="成人影片导航，支持分类、女优、关键词搜索和多线路播放。" />
  </head>
  <body>
    <Header siteName={siteName} />
    <main class="page py-6">
      <section class="mb-8">
        <form class="mx-auto grid max-w-3xl grid-cols-[1fr_auto] gap-2 rounded-md border border-zinc-800 bg-zinc-900/90 p-2 shadow-2xl shadow-black/30 focus-within:border-rose-500" action="/search">
          <input class="min-w-0 rounded bg-zinc-950 px-4 py-4 text-base text-white outline-none placeholder:text-zinc-500" name="q" placeholder="搜索片名、女优、番号、标签" />
          <button class="rounded bg-rose-600 px-6 py-4 text-base font-bold text-white hover:bg-rose-500">搜索</button>
        </form>
        {error && <p class="mt-3 text-center text-sm text-red-400">数据读取失败：{error}</p>}
      </section>

      <section class="mb-9">
        <div class="mb-3 flex items-end justify-between gap-3">
          <h2 class="text-xl font-bold">最新更新</h2>
          <a class="text-sm text-rose-400 hover:text-rose-300" href="/category/latest">加载更多</a>
        </div>
        <VideoGrid items={latest} />
      </section>

      <section class="mb-9">
        <div class="mb-3 flex items-end justify-between gap-3">
          <h2 class="text-xl font-bold">国产</h2>
          <a class="text-sm text-zinc-400 hover:text-white" href="/category/国产">更多</a>
        </div>
        <VideoGrid items={domestic} />
      </section>

      <section class="mb-9">
        <div class="mb-3 flex items-end justify-between gap-3">
          <h2 class="text-xl font-bold">黑料吃瓜</h2>
          <a class="text-sm text-zinc-400 hover:text-white" href="/tag/黑料">更多</a>
        </div>
        <VideoGrid items={gossip} />
      </section>

      <section class="mb-9">
        <div class="mb-3 flex items-end justify-between gap-3">
          <h2 class="text-xl font-bold">日韩</h2>
          <a class="text-sm text-zinc-400 hover:text-white" href="/category/日韩">更多</a>
        </div>
        <VideoGrid items={japanKorea} />
      </section>

      <section class="mb-9">
        <div class="mb-3 flex items-end justify-between gap-3">
          <h2 class="text-xl font-bold">热门</h2>
          <a class="text-sm text-zinc-400 hover:text-white" href="/category/hot">更多</a>
        </div>
        <VideoGrid items={hot} />
      </section>
    </main>
  </body>
</html>

---
import "../styles/global.css";
import Header from "../components/Header.astro";
import KeywordSearchPanel from "../components/KeywordSearchPanel.astro";
import { listActresses } from "../lib/catalog";
import { env } from "../lib/env";

const runtime = env(Astro);
const siteName = runtime.SITE_NAME || "成人视频导航";
const page = Math.max(Number(Astro.url.searchParams.get("page") || 1), 1);
const limit = 24;
const offset = (page - 1) * limit;
const actresses = await listActresses(runtime, { limit, offset, scanLimit: Math.max(12000, (page + 1) * limit * 80) });
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>女优找片 - {siteName}</title>
  </head>
  <body>
    <Header siteName={siteName} />
    <main class="main-offset page">
      <h1 class="clone-title">女优找片</h1>
      <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
        {actresses.map((item) => (
          <a class="adult-card border border-[#e8c2d2] p-2 hover:border-[#ba4a7b]" href={`/actress/${encodeURIComponent(item.name)}`}>
            <span class="poster-frame">
              <img class="poster-img" src={item.pic || "/favicon.svg"} alt={item.name} loading="lazy" />
            </span>
            <span class="block p-3">
              <span class="block truncate font-semibold text-[#ba4a7b]">{item.name}</span>
              <span class="mt-1 block text-xs text-neutral-500">{item.count} 部相关</span>
            </span>
          </a>
        ))}
      </div>
      <div class="mt-7 flex justify-center gap-3">
        {page > 1 && <a class="pill" href={`/actresses?page=${page - 1}`}>上一页</a>}
        {actresses.length === limit && <a class="pill" href={`/actresses?page=${page + 1}`}>下一页</a>}
      </div>
      <KeywordSearchPanel class="mt-10" />
    </main>
  </body>
</html>

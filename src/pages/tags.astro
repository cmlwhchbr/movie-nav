---
import "../styles/global.css";
import Header from "../components/Header.astro";
import { env } from "../lib/env";
import { hotTags, makerTags, safeTags, sceneTags, specialTags } from "../lib/tags";

const runtime = env(Astro);
const siteName = runtime.SITE_NAME || "成人视频导航";
const sections = [
  ["场景标签", safeTags(sceneTags)],
  ["制片商标签", safeTags(makerTags)],
  ["热门标签", safeTags(hotTags)],
  ["专题标签", safeTags(specialTags)]
];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>关键词找片 - {siteName}</title>
  </head>
  <body>
    <Header siteName={siteName} />
    <main class="main-offset page">
      <div class="clone-arrow"><img src="/clone-assets/fleche.png" alt="" /></div>
      <h1 class="clone-title">关键词找片</h1>
      {sections.map(([title, tags]) => (
        <section class="keyword-panel">
          <div class="mb-3 flex items-center justify-center gap-3">
            <h2>{title}</h2>
            <span class="text-sm text-neutral-500">{tags.length}</span>
          </div>
          <div class="keyword-panel__links">
            {tags.map((tag) => <a class="pill" href={`/tag/${encodeURIComponent(tag)}`}>{tag}</a>)}
          </div>
        </section>
      ))}
    </main>
  </body>
</html>

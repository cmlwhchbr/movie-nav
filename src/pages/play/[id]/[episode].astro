---
import "../../../styles/global.css";
import { detailUrl, getVodDetailFromSources, isDirectVideo, playUrl } from "../../../lib/maccms";
import { env } from "../../../lib/env";

const runtime = env(Astro);
const id = Astro.params.id || "";
const episodeIndex = Number(Astro.params.episode || 0);
const source = Astro.url.searchParams.has("source") ? Number(Astro.url.searchParams.get("source")) : undefined;
const vod = await getVodDetailFromSources(runtime, id, source);

if (!vod) {
  return new Response("Not Found", { status: 404 });
}

const current = vod.episodes[episodeIndex];
if (!current) {
  return new Response("Not Found", { status: 404 });
}

const playerUrl = vod.source === 3 || current.player === "aosika"
  ? `https://askvodbf.com/play.html?url=${encodeURIComponent(current.url)}`
  : current.url;
const useIframePlayer = vod.source === 3 || current.player === "aosika" || !isDirectVideo(current.url);
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{current.name} - {vod.name} - {runtime.SITE_NAME}</title>
  </head>
  <body>
    <header class="topbar">
      <div class="page bar">
        <a class="brand" href="/">{runtime.SITE_NAME}</a>
        <nav class="nav"><a href="/">首页</a><a href={detailUrl(vod)}>详情</a></nav>
      </div>
    </header>
    <main class="page">
      <section class="hero">
        <h1>{vod.name}</h1>
        <p class="muted">{current.name}</p>
      </section>
      <section class="panel">
        {!useIframePlayer ? (
          <video class="player" src={playerUrl} controls playsinline preload="metadata"></video>
        ) : (
          <iframe class="player" src={playerUrl} allow="autoplay; encrypted-media; picture-in-picture; fullscreen" allowfullscreen></iframe>
        )}
        <p><a href={current.url} target="_blank" rel="nofollow noopener">新窗口打开播放地址</a></p>
      </section>
      <section class="panel" style="margin-top: 16px">
        <h2>播放列表</h2>
        <div class="episodes">
          {vod.episodes.map((ep) => (
            <a href={playUrl(vod, ep.index)}>{ep.name}</a>
          ))}
        </div>
      </section>
    </main>
  </body>
</html>

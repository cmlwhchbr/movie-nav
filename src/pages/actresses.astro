---
import "../styles/global.css";
import Header from "../components/Header.astro";
import KeywordSearchPanel from "../components/KeywordSearchPanel.astro";
import { listActresses } from "../lib/catalog";
import { env } from "../lib/env";

const runtime = env(Astro);
const siteName = runtime.SITE_NAME || "成人视频导航";
const [japanActresses, domesticActresses] = await Promise.all([
  listActresses(runtime, { group: "japan", limit: 160, scanLimit: 60000 }),
  listActresses(runtime, { group: "domestic", limit: 160, scanLimit: 60000 })
]);
const sections = [
  ["日本女优", japanActresses],
  ["国产传媒演员", domesticActresses]
] as const;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>演员找片 - {siteName}</title>
  </head>
  <body>
    <Header siteName={siteName} />
    <main class="main-offset page">
      <h1 class="clone-title">演员找片</h1>
      <div class="actor-tabs" role="tablist" aria-label="演员分类">
        {sections.map(([title], index) => (
          <button class={`actor-tab ${index === 0 ? "is-active" : ""}`} type="button" role="tab" aria-selected={index === 0 ? "true" : "false"} data-actor-tab={String(index)}>
            {title}
          </button>
        ))}
      </div>
      {sections.map(([title, items], index) => (
        <section class={`keyword-panel actor-panel ${index === 0 ? "is-active" : ""}`} data-actor-panel={String(index)}>
          <h2>{title}</h2>
          <div class="keyword-panel__links">
            {items.map((item) => (
              <a href={`/search?q=${encodeURIComponent(item.name)}`} title={item.name}>
                {item.name}
              </a>
            ))}
          </div>
        </section>
      ))}
      <KeywordSearchPanel class="mt-10" />
    </main>
    <script>
      const tabs = [...document.querySelectorAll<HTMLButtonElement>("[data-actor-tab]")];
      const panels = [...document.querySelectorAll<HTMLElement>("[data-actor-panel]")];

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const target = tab.dataset.actorTab || "0";
          tabs.forEach((item) => {
            const active = item.dataset.actorTab === target;
            item.classList.toggle("is-active", active);
            item.setAttribute("aria-selected", active ? "true" : "false");
          });
          panels.forEach((panel) => {
            panel.classList.toggle("is-active", panel.dataset.actorPanel === target);
          });
        });
      });
    </script>
  </body>
</html>

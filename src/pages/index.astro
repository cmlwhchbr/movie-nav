---
import "../styles/global.css";
import Header from "../components/Header.astro";
import VideoGrid from "../components/VideoGrid.astro";
import { listCatalogVideos } from "../lib/catalog";
import { env } from "../lib/env";

const runtime = env(Astro);
const siteName = runtime.SITE_NAME || "成人视频导航";
let latest = [];
let domestic = [];
let gossip = [];
let japanKorea = [];
let hot = [];
let error = "";
const hotSearchTerms = ["国产主播", "黑料吃瓜", "抖阴短片", "91探花", "学生少女", "高潮喷水", "麻豆", "果冻"];

try {
  [latest, domestic, gossip, japanKorea, hot] = await Promise.all([
    listCatalogVideos(runtime, { order: "latest", limit: 18 }),
    listCatalogVideos(runtime, { type: "国产", order: "latest", limit: 9 }),
    listCatalogVideos(runtime, { tag: "黑料", order: "latest", limit: 9 }),
    listCatalogVideos(runtime, { type: "日韩", order: "latest", limit: 9 }),
    listCatalogVideos(runtime, { type: "国产", order: "hot", limit: 9 })
  ]);
} catch (exception) {
  error = exception instanceof Error ? exception.message : "数据读取失败";
}
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteName}</title>
    <meta name="description" content="成人影片导航，支持分类、女优、关键词搜索和多线路播放。" />
  </head>
  <body>
    <Header siteName={siteName} />
    <main class="main-offset">
      <section class="page pt-5">
        <form class="mx-auto grid max-w-3xl grid-cols-[1fr_auto] gap-0 overflow-hidden rounded-md border border-[#ba4a7b] bg-white shadow-md" action="/search">
          <input class="min-w-0 px-4 py-3 text-base text-neutral-700 outline-none placeholder:text-neutral-400" name="q" placeholder="搜索片名、女优、番号、标签" />
          <button class="bg-[#ba4a7b] px-6 py-3 text-base font-bold text-white hover:bg-[#a23b6b]">搜寻</button>
        </form>
        <div class="mx-auto mt-4 flex max-w-3xl flex-wrap items-center justify-center gap-2">
          {hotSearchTerms.map((term) => (
            <a class="rounded border border-[#ba4a7b] bg-white px-3 py-2 text-sm text-[#ba4a7b] hover:bg-[#ba4a7b] hover:text-white" href={`/search?q=${encodeURIComponent(term)}`}>
              {term}
            </a>
          ))}
        </div>
        {error && <p class="mt-3 text-center text-sm text-red-600">数据读取失败：{error}</p>}
      </section>

      <section class="page">
        <h1 class="clone-title">推荐影片</h1>
        <div class="clone-more"><a href="/category/国产">所有国产影片&gt;&gt;</a></div>
        <VideoGrid items={hot} />
      </section>

      <section class="clone-banner">
        <span class="clone-banner__name">老司机 laosiji.xyz</span>
        <span class="clone-banner__line">每日更新 D1 资源库 <a class="clone-banner__button" href="/category/latest">&gt;&gt;</a></span>
      </section>

      <section class="page">
        <h2 class="clone-title">所有最新影片:</h2>
        <div class="clone-more"><a href="/category/latest">更多最新影片&gt;&gt;</a></div>
        <VideoGrid items={latest} />
      </section>

      <section class="page">
        <h2 class="clone-title">国产</h2>
        <div class="clone-more"><a href="/category/国产">所有国产影片&gt;&gt;</a></div>
        <VideoGrid items={domestic} />
      </section>

      <section class="page">
        <h2 class="clone-title">黑料吃瓜</h2>
        <div class="clone-more"><a href="/tag/黑料">所有黑料吃瓜影片&gt;&gt;</a></div>
        <VideoGrid items={gossip} />
      </section>

      <section class="page">
        <h2 class="clone-title">日韩</h2>
        <div class="clone-more"><a href="/category/日韩">所有日韩影片&gt;&gt;</a></div>
        <VideoGrid items={japanKorea} />
      </section>

      <footer class="clone-footer">
        <a href="/">老司机 laosiji.xyz</a>
        <p>每日更新影视资源导航</p>
      </footer>
    </main>
  </body>
</html>
